{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*).(css|js|png|jpg|svg|ico)",
      "dest": "frontend/$0"
    },
    {
      "src": "/(.*).html",
      "dest": "frontend/$1.html"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}
